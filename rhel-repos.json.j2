{# templates/rhel-repos.json.j2
   Renders a repo definition keyed by arch for the given rhel_version.
   EUS repos exist for 8.x/9.x minor releases. For RHEL 10, .0 uses GA repos;
   later minors use EUS. We derive the major/minor and pick the CDN path.

   NOTE ON check_gpg = false:
   Current Red Hat redhat-release packages ship a V6-format (Post-Quantum
   Cryptography) GPG key that the osbuild worker's rpmkeys cannot yet import,
   causing builds to fail at the GPG-import step with:
       "Unsupported version of key: V6 ... key N import failed".
   This is a known osbuild/tooling lag (Red Hat Access Solution 7136467), not
   a problem with the RPM content itself. Red Hat's documented workaround is a
   repo override with check_gpg = false. Packages are still pulled from Red
   Hat's official CDN over TLS (rhsm=true), so transport is authenticated; we
   are only skipping per-package signature verification AT BUILD TIME. Re-enable
   check_gpg once the builder's osbuild stack can parse V6 keys. #}
{%- set major = rhel_version.split('.')[0] -%}
{%- set minor = rhel_version.split('.')[1] -%}
{%- if major == "10" and minor == "0" -%}
{%- set repo_base = "dist/rhel" ~ major ~ "/" ~ rhel_version -%}
{%- else -%}
{%- set repo_base = "eus/rhel" ~ major ~ "/" ~ rhel_version -%}
{%- endif -%}
{
    "{{ arch }}": [
        {
            "name": "baseos",
            "metalink": "",
            "baseurl": "https://cdn.redhat.com/content/{{ repo_base }}/{{ arch }}/baseos/os/",
            "mirrorlist": "",
            "gpgkey": "file:///etc/pki/rpm-gpg/RPM-GPG-KEY-redhat-release",
            "check_gpg": false,
            "metadata_expire": "",
            "rhsm": true
        },
        {
            "name": "appstream",
            "metalink": "",
            "baseurl": "https://cdn.redhat.com/content/{{ repo_base }}/{{ arch }}/appstream/os/",
            "mirrorlist": "",
            "gpgkey": "file:///etc/pki/rpm-gpg/RPM-GPG-KEY-redhat-release",
            "check_gpg": false,
            "metadata_expire": "",
            "rhsm": true
        }
    ]
}
